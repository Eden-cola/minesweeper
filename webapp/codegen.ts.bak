  schema: path.resolve(__dirname, "../contract/schema.graphql"),
  documents: [
    "src/**/*.{graphql,ts,tsx}",
  ],
  generates: {
    "src/gql/": {
      preset: "client",
    },
    "../contract/schema.graphql": {
      plugins: ["schema-ast"],
    },
  },
};

export default config;
